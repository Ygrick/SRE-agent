# === PostgreSQL (общий пользователь для всех БД) ===
POSTGRES_USER=ai_sre
POSTGRES_PASSWORD=changeme-secure-password

# === LiteLLM Gateway ===
LITELLM_MASTER_KEY=sk-master-changeme
LITELLM_DATABASE_URL=postgresql://ai_sre:changeme-secure-password@litellm-postgres:5432/litellm

# === LLM Provider (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-changeme
# Добавить провайдера: docs/guides/add-provider.md

# === Langfuse ===
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_NEXTAUTH_SECRET=changeme-langfuse-secret
LANGFUSE_SALT=changeme-langfuse-salt

# === Grafana ===
GRAFANA_PASSWORD=admin

# === Agent ===
AGENT_GATEWAY_URL=http://litellm:4000
AGENT_GATEWAY_API_KEY=sk-master-changeme
AGENT_REGISTRY_API_KEY=changeme-registry-key
AGENT_TELEGRAM_BOT_TOKEN=changeme
AGENT_TELEGRAM_CHAT_ID=changeme
AGENT_CODEX_MODEL=step-3.5-flash

# === Registry ===
REGISTRY_DATABASE_URL=postgresql+asyncpg://ai_sre:changeme-secure-password@postgres:5432/ai_sre
REGISTRY_API_KEY=changeme-registry-key
